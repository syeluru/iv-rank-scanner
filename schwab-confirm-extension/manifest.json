{
  "manifest_version": 3,
  "name": "Schwab Trade Confirm",
  "version": "1.0",
  "description": "Forces confirmation on every button click on Schwab to prevent accidental trades",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "*://*.schwab.com/*",
        "*://*.schwabplan.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
